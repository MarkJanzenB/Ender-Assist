<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.ActiveJobPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModernCard}">
        <StackPanel>
            <TextBlock Text="Active Job" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="{Binding CurrentJobName}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16">
                <Run Text="State: "/><Run Text="{Binding PrintStateText}" FontWeight="SemiBold"/>
            </TextBlock>

            <Grid Height="36" Margin="0,0,0,12">
                <Border Background="{StaticResource SurfaceMutedBrush}" CornerRadius="8"/>
                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="36"/>
                <TextBlock Text="{Binding Progress, StringFormat={}{0:F1}%}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ELAPSED" Style="{StaticResource FieldLabel}" Margin="0"/>
                    <TextBlock Text="{Binding ElapsedText}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ETA" Style="{StaticResource FieldLabel}" Margin="0"/>
                    <TextBlock Text="{Binding EtaText}" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,0,0,12">
                <Button Content="▶ Start" Style="{StaticResource PrimaryButton}" Command="{Binding StartPrintCommand}"/>
                <Button Content="Pause" Command="{Binding PausePrintCommand}"/>
                <Button Content="Resume" Command="{Binding ResumePrintCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelPrintCommand}"/>
            </WrapPanel>

            <Border CornerRadius="12" Padding="12" Background="{StaticResource DangerMutedBrush}"
                    BorderBrush="{StaticResource DangerBrush}" BorderThickness="1">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource DangerButton}" Content="E-STOP"
                            Command="{Binding EmergencyStopCommand}" ToolTip="F12"/>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Emergency Stop" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock Text="M112 · Full reset required" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
