<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.ConsolePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModernCard}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Serial Console" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ComboBox Width="100" SelectedIndex="{Binding ConsoleFilterIndex}" Margin="0,0,8,0">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="RX"/>
                        <ComboBoxItem Content="TX"/>
                        <ComboBoxItem Content="Errors"/>
                    </ComboBox>
                    <Button Content="Clear" Style="{StaticResource GhostButton}" Command="{Binding ClearConsoleCommand}"/>
                </StackPanel>
            </DockPanel>

            <Border DockPanel.Dock="Bottom" Background="{StaticResource InsetBrush}" CornerRadius="8" Padding="8" MinHeight="120" MaxHeight="200">
                <ListBox ItemsSource="{Binding ConsoleLines}" FontFamily="Cascadia Mono, Consolas, Segoe UI" FontSize="11"/>
            </Border>

            <DockPanel Margin="0,8,0,0">
                <Button DockPanel.Dock="Right" Content="Send" Style="{StaticResource PrimaryButton}" Command="{Binding SendConsoleCommand}" Margin="8,0,0,0"/>
                <TextBox Text="{Binding ConsoleInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="ConsoleInput_KeyDown"
                         FontFamily="Cascadia Mono, Consolas, Segoe UI"/>
            </DockPanel>
        </DockPanel>
    </Border>
</UserControl>
