<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.HistoryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MarlinPrintMiddleware.UI.Converters">
    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
    </UserControl.Resources>
    <Border Style="{StaticResource ModernCard}">
        <DockPanel>
            <TextBlock Text="Print History" Style="{StaticResource SectionTitle}" DockPanel.Dock="Top" Margin="0"/>
            <Grid MinHeight="300">
                <DataGrid ItemsSource="{Binding HistoryJobs}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="JOB" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="COMPLETED" Binding="{Binding CompletedAt}" Width="160"/>
                        <DataGridTextColumn Header="LAYERS" Binding="{Binding TotalLayers}" Width="70"/>
                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="24"
                        Visibility="{Binding HistoryJobs.Count, Converter={StaticResource CountToVis}, ConverterParameter=empty}">
                    <TextBlock Text="No finished jobs yet." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
