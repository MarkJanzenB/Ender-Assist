<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.LiveMonitorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MarlinPrintMiddleware.UI.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border Style="{StaticResource ModernCard}">
        <StackPanel>
            <TextBlock Text="Live Monitor" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="NOZZLE" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text="{Binding HotendDisplay}" Style="{StaticResource MetricValue}"/>
                        <TextBlock FontSize="12" Margin="0,4,0,0">
                            <Run Text="Target " Foreground="{StaticResource TextTertiaryBrush}"/>
                            <Run Text="{Binding HotendTargetDisplay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource HeatingPill}" VerticalAlignment="Center"
                            Visibility="{Binding IsHotendHeating, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding HotendHeatingLabel}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeatingBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="BED" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text="{Binding BedDisplay}" Style="{StaticResource MetricValue}"/>
                        <TextBlock FontSize="12" Margin="0,4,0,0">
                            <Run Text="Target " Foreground="{StaticResource TextTertiaryBrush}"/>
                            <Run Text="{Binding BedTargetDisplay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource HeatingPill}" VerticalAlignment="Center"
                            Visibility="{Binding IsBedHeating, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BedHeatingLabel}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HeatingBrush}"/>
                    </Border>
                </Grid>
            </Border>
            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="FAN" Style="{StaticResource FieldLabel}" Margin="0"/>
                    <TextBlock Text="{Binding FanDisplay}" Style="{StaticResource MetricValue}" FontSize="24"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="POSITION" Style="{StaticResource FieldLabel}" Margin="0"/>
                    <TextBlock Text="{Binding PositionDisplay}" FontFamily="Cascadia Mono, Consolas, Segoe UI" FontSize="14"/>
                    <TextBlock Margin="0,8,0,0" FontSize="12">
                        <Run Text="Layers " Foreground="{StaticResource TextTertiaryBrush}"/>
                        <Run Text="{Binding LayerDisplay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
