<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.MacrosPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ModernCard}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,16,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Macros" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0"/>
                    <Button DockPanel.Dock="Right" Content="Run" Style="{StaticResource PrimaryButton}" Command="{Binding RunMacroCommand}"/>
                </DockPanel>
                <ListBox ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedMacro}" DisplayMemberPath="Name"/>
            </DockPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="EDIT MACRO" Style="{StaticResource FieldLabel}"/>
                <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding MacroName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <TextBlock Text="G-code command" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding MacroCommand, UpdateSourceTrigger=PropertyChanged}" MinHeight="80"
                         TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Cascadia Mono, Consolas, Segoe UI"/>
                <WrapPanel Margin="0,12,0,0">
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveMacroCommand}"/>
                    <Button Content="New" Command="{Binding NewMacroCommand}"/>
                    <Button Content="Delete" Command="{Binding DeleteMacroCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
