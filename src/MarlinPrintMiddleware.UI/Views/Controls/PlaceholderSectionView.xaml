<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.PlaceholderSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource ModernCard}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480" Padding="40">
        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title, ElementName=Root}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Message, ElementName=Root}" Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
