<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.QueuePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MarlinPrintMiddleware.UI.Converters">
    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border Style="{StaticResource ModernCard}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Print Queue" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0"/>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="+ Add G-code" Style="{StaticResource PrimaryButton}" Command="{Binding AddGCodeCommand}"/>
                    <Button Content="Remove" Style="{StaticResource GhostButton}" Command="{Binding RemoveJobCommand}"/>
                    <Button Content="Retry" Style="{StaticResource GhostButton}" Command="{Binding RetryJobCommand}"/>
                    <Button Content="Clear done" Style="{StaticResource GhostButton}" Command="{Binding ClearCompletedCommand}"/>
                </WrapPanel>
            </DockPanel>

            <Grid MinHeight="180">
                <DataGrid x:Name="JobsGrid" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}"
                          PreviewMouseLeftButtonDown="JobsGrid_PreviewMouseLeftButtonDown"
                          MouseMove="JobsGrid_MouseMove"
                          AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="JOB" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="LAYERS" Binding="{Binding TotalLayers}" Width="70"/>
                        <DataGridTemplateColumn Header="PROGRESS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="20" Margin="0,2">
                                        <Border Background="{StaticResource SurfaceMutedBrush}" CornerRadius="6"/>
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="20"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F0}%}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="24"
                        Visibility="{Binding Jobs.Count, Converter={StaticResource CountToVis}, ConverterParameter=empty}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No jobs queued" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add a G-code file or drag one here." Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        <Button Content="+ Add G-code" Style="{StaticResource PrimaryButton}" Command="{Binding AddGCodeCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
