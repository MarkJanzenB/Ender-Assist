<UserControl x:Class="MarlinPrintMiddleware.UI.Views.Controls.SettingsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MarlinPrintMiddleware.UI.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border Style="{StaticResource ModernCard}" MaxWidth="560" HorizontalAlignment="Left">
        <StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="Connection port and baud are saved with your Ender 3 v2 profile."
                       Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="SERIAL PORT" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding PortName}" FontWeight="SemiBold"/>
                                <Run Text=" · " Foreground="{StaticResource TextMutedBrush}"/>
                                <Run Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="BAUD RATE" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding BaudRate}"/>
            </StackPanel>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Margin="0,0,0,16">
                <CheckBox Content="Auto-start next job when one finishes" IsChecked="{Binding AutoStartQueue}"/>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="16"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                <CheckBox Content="Use dark theme" IsChecked="{Binding IsDarkTheme}"/>
            </Border>

            <Border Background="{StaticResource HeatingMutedBrush}" CornerRadius="8" Padding="10,6" Margin="0,12,0,0"
                    Visibility="{Binding HasUnsavedSettings, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Unsaved changes" Foreground="{StaticResource HeatingBrush}" FontWeight="SemiBold" FontSize="12"/>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Save settings" Style="{StaticResource PrimaryButton}" Command="{Binding SaveSettingsCommand}"/>
                <Button Content="Refresh ports" Style="{StaticResource GhostButton}" Command="{Binding RefreshPortsCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
