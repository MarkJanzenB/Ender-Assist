<Window x:Class="MarlinPrintMiddleware.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MarlinPrintMiddleware.UI.Converters"
        xmlns:ctrl="clr-namespace:MarlinPrintMiddleware.UI.Views.Controls"
        xmlns:enums="clr-namespace:MarlinPrintMiddleware.UI.Enums"
        Title="Ender Assist" Height="900" Width="1320"
        MinHeight="700" MinWidth="1100"
        Background="#0A0D12"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ConnectionStateToBrushConverter x:Key="ConnBrush"/>
        <conv:ConnectionStateToLabelConverter x:Key="ConnLabel"/>
        <conv:NavSectionToVisibilityConverter x:Key="SectionVis"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F12" Command="{Binding EmergencyStopCommand}"/>
    </Window.InputBindings>

    <Grid Background="{StaticResource ShellGradientBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Nav rail -->
        <Border Grid.Column="0" Background="{StaticResource ShellElevatedBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,16">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,0,20">
                    <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2DD4BF" Offset="0"/>
                                <GradientStop Color="#14B8A6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="EA" FontWeight="Bold" Foreground="#042F2E"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ender Assist" FontWeight="SemiBold" FontSize="15"/>
                        <TextBlock Text="Workshop panel" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                        <TextBlock Text="v1.0.0" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="12,8"/>

                <!-- Printer card -->
                <Border DockPanel.Dock="Bottom" Style="{StaticResource ModernCard}" Margin="0,12,0,8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding PrinterModel}" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding ConnectionState, Converter={StaticResource ConnBrush}}"/>
                            <TextBlock Text="{Binding ConnectionState, Converter={StaticResource ConnLabel}}" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Port "/><Run Text="{Binding PortDisplay}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="Baud "/><Run Text="{Binding BaudRate}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding FirmwareInfo}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                            <Run Text="Board "/><Run Text="{Binding BoardInfo}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding NavItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource NavButton}"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Section}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{Binding IconData}" Fill="{StaticResource TextMutedBrush}"
                                          Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding Label}" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Thermal banner -->
            <Border Grid.Row="0" Style="{StaticResource WarningBanner}" Margin="16,12,16,0"
                    Visibility="{Binding HasThermalWarning, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Dismiss" Style="{StaticResource GhostButton}"
                            Command="{Binding DismissThermalWarningCommand}"/>
                    <TextBlock Text="{Binding ThermalWarningMessage}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </DockPanel>
            </Border>

            <!-- Status strip -->
            <Border Grid.Row="1" Background="{StaticResource CardBrush}" Margin="16,12,16,0"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusHeroText}" FontSize="28" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding StatusHeroSubtext}" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="8,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="NOZZLE" Style="{StaticResource FieldLabel}" Margin="0"/>
                            <TextBlock FontSize="20" FontWeight="SemiBold">
                                <Run Text="{Binding HotendDisplay}"/><Run Text=" / " Foreground="{StaticResource TextTertiaryBrush}"/><Run Text="{Binding HotendTargetDisplay}" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource MetricCard}" Margin="8,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="BED" Style="{StaticResource FieldLabel}" Margin="0"/>
                            <TextBlock FontSize="20" FontWeight="SemiBold">
                                <Run Text="{Binding BedDisplay}"/><Run Text=" / " Foreground="{StaticResource TextTertiaryBrush}"/><Run Text="{Binding BedTargetDisplay}" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource MetricCard}" Margin="8,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="FAN" Style="{StaticResource FieldLabel}" Margin="0"/>
                            <TextBlock Text="{Binding FanDisplay}" FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Connect" Style="{StaticResource PrimaryButton}" Command="{Binding ConnectCommand}" Margin="8,0,0,0"/>
                        <Button Content="Disconnect" Command="{Binding DisconnectCommand}"/>
                        <Button Content="⚙" Style="{StaticResource GhostButton}" Command="{Binding GoToSettingsCommand}" ToolTip="Settings" MinWidth="44"/>
                    </StackPanel>
                </Grid>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Border.Effect>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="16,12,16,0">
                <Grid>
                    <!-- Dashboard -->
                    <Grid Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=Dashboard}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ctrl:QueuePanelView Grid.Row="0" Grid.Column="0" Margin="0,0,6,6"/>
                            <ctrl:ActiveJobPanelView Grid.Row="0" Grid.Column="1" Margin="6,0,0,6"/>
                            <ctrl:LiveMonitorPanelView Grid.Row="1" Grid.Column="0" Margin="0,6,6,0"/>
                            <ctrl:ControlPanelView Grid.Row="1" Grid.Column="1" Margin="6,6,0,0"/>
                        </Grid>
                        <ctrl:ConsolePanelView Grid.Row="1" Margin="0,12,0,0"/>
                    </Grid>

                    <ctrl:QueuePanelView Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=Queue}" Margin="0,0,0,8"/>
                    <ctrl:SettingsPanelView Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=Settings}"/>

                    <ctrl:TerminalSectionView Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=Terminal}"/>
                    <ctrl:MacrosPanelView Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=Macros}"/>
                    <ctrl:HistoryPanelView Visibility="{Binding CurrentSection, Converter={StaticResource SectionVis}, ConverterParameter=History}"/>
                </Grid>
            </ScrollViewer>

            <!-- Busy bar -->
            <ProgressBar Grid.Row="3" Style="{StaticResource ProgressBarIndeterminate}" Margin="16,8,16,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

            <!-- Footer -->
            <Border Grid.Row="4" Background="{StaticResource ShellElevatedBrush}" Padding="16,8" Margin="0,8,0,0"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding FooterSummary}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
